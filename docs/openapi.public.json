{
  "openapi": "3.0.3",
  "info": {
    "title": "Hope Apartments Partner API",
    "version": "1.0.0",
    "description": "Public partner-facing documentation for the Hope Apartments API. This spec only includes the external integration surface."
  },
  "tags": [
    {
      "name": "Apartments",
      "description": "Partner apartment export endpoints"
    }
  ],
  "paths": {
    "/api/v1/apartments": {
      "get": {
        "tags": [
          "Apartments"
        ],
        "summary": "Fetch all live apartments",
        "description": "Returns the full apartment collection available to the authenticated partner.",
        "security": [
          {
            "partnerApiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Normalized apartment payload",
            "headers": {
              "x-data-source": {
                "schema": {
                  "type": "string"
                },
                "description": "Data source marker",
                "example": "live-onoffice"
              },
              "x-ratelimit-limit": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-remaining": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-reset": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated but not authorized for this endpoint",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "409": {
            "description": "Another live onOffice sync is already running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "headers": {
              "retry-after": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "500": {
            "description": "Upstream fetch or mapping failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "503": {
            "description": "Partner API key auth is not configured on the server",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apartments/rental": {
      "get": {
        "tags": [
          "Apartments"
        ],
        "summary": "Fetch live rental apartments",
        "description": "Returns only rental apartments available to the authenticated partner.",
        "security": [
          {
            "partnerApiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Normalized rental apartment payload",
            "headers": {
              "x-data-source": {
                "schema": {
                  "type": "string"
                },
                "description": "Data source marker",
                "example": "live-onoffice"
              },
              "x-ratelimit-limit": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-remaining": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-reset": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated but not authorized for this endpoint",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "409": {
            "description": "Another live onOffice sync is already running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "headers": {
              "retry-after": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "500": {
            "description": "Upstream fetch or mapping failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "503": {
            "description": "Partner API key auth is not configured on the server",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apartments/onsale": {
      "get": {
        "tags": [
          "Apartments"
        ],
        "summary": "Fetch live on-sale apartments",
        "description": "Returns only apartments available for sale to the authenticated partner.",
        "security": [
          {
            "partnerApiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Normalized on-sale apartment payload",
            "headers": {
              "x-data-source": {
                "schema": {
                  "type": "string"
                },
                "description": "Data source marker",
                "example": "live-onoffice"
              },
              "x-ratelimit-limit": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-remaining": {
                "schema": {
                  "type": "string"
                }
              },
              "x-ratelimit-reset": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated but not authorized for this endpoint",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "409": {
            "description": "Another live onOffice sync is already running",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "headers": {
              "retry-after": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "500": {
            "description": "Upstream fetch or mapping failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "503": {
            "description": "Partner API key auth is not configured on the server",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/apartments/{id}": {
      "get": {
        "tags": [
          "Apartments"
        ],
        "summary": "Fetch a single apartment by id",
        "description": "Returns one apartment from the authenticated partner dataset by id.",
        "security": [
          {
            "partnerApiKey": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Apartment identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Normalized apartment payload",
            "headers": {
              "x-data-source": {
                "schema": {
                  "type": "string"
                },
                "description": "Data source marker",
                "example": "live-onoffice"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApartmentDetailResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated but not authorized for this endpoint",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "404": {
            "description": "Apartment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "500": {
            "description": "Upstream fetch or mapping failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          },
          "503": {
            "description": "Partner API key auth is not configured on the server",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "partnerApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Partner API key used to authenticate requests."
      }
    },
    "schemas": {
      "PublicError": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string",
            "example": "FORBIDDEN"
          },
          "message": {
            "type": "string",
            "example": "You are not authorized to access this resource."
          }
        },
        "required": [
          "status",
          "code",
          "message"
        ]
      },
      "ApartmentListResponse": {
        "type": "object",
        "properties": {
          "apartments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Apartment"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "required": [
          "apartments",
          "meta"
        ]
      },
      "Apartment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "latitude": {
            "type": "number",
            "nullable": true,
            "example": 52.520008
          },
          "longitude": {
            "type": "number",
            "nullable": true,
            "example": 13.404954
          },
          "roomsTotal": {
            "type": "number",
            "nullable": true,
            "example": 3
          },
          "bedrooms": {
            "type": "number",
            "nullable": true,
            "example": 2
          },
          "bathrooms": {
            "type": "number",
            "nullable": true,
            "example": 1
          },
          "areaSqft": {
            "type": "number",
            "nullable": true,
            "example": 538.19
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Photo"
            }
          },
          "features": {
            "$ref": "#/components/schemas/Features"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "locationDescription": {
            "type": "string",
            "nullable": true
          },
          "equipmentDescription": {
            "type": "string",
            "nullable": true
          },
          "availability": {
            "$ref": "#/components/schemas/Availability"
          },
          "rent": {
            "$ref": "#/components/schemas/Rent"
          },
          "deposit": {
            "type": "string",
            "nullable": true
          },
          "floorLevel": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "address",
          "latitude",
          "longitude",
          "roomsTotal",
          "bedrooms",
          "bathrooms",
          "areaSqft",
          "photos",
          "features",
          "description",
          "locationDescription",
          "equipmentDescription",
          "availability",
          "rent",
          "deposit",
          "floorLevel"
        ]
      },
      "Address": {
        "type": "object",
        "properties": {
          "buildingNumber": {
            "type": "string",
            "nullable": true
          },
          "streetName": {
            "type": "string",
            "nullable": true
          },
          "neighborhood": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "string"
            }
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "zipCode": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "buildingNumber",
          "streetName",
          "neighborhood",
          "city",
          "zipCode"
        ]
      },
      "Photo": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "originalname": {
            "type": "string",
            "nullable": true
          },
          "modified": {
            "nullable": true,
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "required": [
          "url",
          "type",
          "title",
          "originalname",
          "modified"
        ]
      },
      "Features": {
        "type": "object",
        "properties": {
          "elevator": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "balcony": {
            "type": "boolean"
          },
          "furnished": {
            "type": "boolean",
            "nullable": true
          }
        },
        "required": [
          "elevator",
          "balcony",
          "furnished"
        ]
      },
      "Availability": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "nullable": true,
            "example": "2026-05-01"
          },
          "until": {
            "type": "string",
            "nullable": true,
            "example": "2026-12-31"
          }
        },
        "required": [
          "from",
          "until"
        ]
      },
      "Rent": {
        "type": "object",
        "properties": {
          "warmRent": {
            "type": "number",
            "nullable": true,
            "example": 1200
          },
          "coldRent": {
            "type": "number",
            "nullable": true,
            "example": 1000
          },
          "currency": {
            "type": "string",
            "example": "EUR"
          }
        },
        "required": [
          "warmRent",
          "coldRent",
          "currency"
        ]
      },
      "ResponseMeta": {
        "type": "object",
        "properties": {
          "requestedBy": {
            "type": "string",
            "example": "partner-a"
          },
          "authType": {
            "type": "string",
            "example": "api_key"
          },
          "count": {
            "type": "integer",
            "example": 84
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "durationMs": {
            "type": "integer",
            "example": 3000
          }
        },
        "required": [
          "requestedBy",
          "authType",
          "count",
          "startedAt",
          "finishedAt",
          "durationMs"
        ]
      },
      "ApartmentDetailResponse": {
        "type": "object",
        "properties": {
          "apartment": {
            "$ref": "#/components/schemas/Apartment"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "required": [
          "apartment",
          "meta"
        ]
      }
    }
  }
}
