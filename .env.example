# ============================================================
# onOffice upstream credentials (required)
# ============================================================
# Base API URL. Keep the default unless onOffice gives you another endpoint.
ONOFFICE_URL=https://api.onoffice.de/api/stable/api.php
# Your onOffice API token.
ONOFFICE_TOKEN=your_onoffice_token_here
# Your onOffice API secret.
ONOFFICE_SECRET=your_onoffice_secret_here

# ============================================================
# Runtime environment
# ============================================================
# Use "development" for local work, "production" on server.
NODE_ENV=development

# ============================================================
# Database and JWT auth (optional, Phase 2)
# ============================================================
# PostgreSQL connection string for real users in database.
DATABASE_URL=
# Enable SSL for PostgreSQL connections. Recommended in production.
DATABASE_SSL=true
# JWT settings for /auth/login and /auth/me.
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_TTL=15m
AUTH_REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=hope-apartments-api
JWT_AUDIENCE=hope-apartments-clients
# Password hashing cost factor.
BCRYPT_ROUNDS=12

# ============================================================
# API server settings
# ============================================================
# HTTP port where this service listens.
EXPORT_API_PORT=3000
# Optional explicit base URL used in internal OpenAPI responses.
OPENAPI_SERVER_URL=
# Optional explicit base URL used in public OpenAPI responses.
OPENAPI_PUBLIC_SERVER_URL=

# Rate limiting for GET /apartments (in-memory, per process)
# Example: 60 requests per 60 seconds per API key (or IP if key missing).
EXPORT_API_RATE_LIMIT_ENABLED=true
EXPORT_API_RATE_LIMIT_WINDOW_SEC=60
EXPORT_API_RATE_LIMIT_MAX_REQUESTS=60
# Rate limiting for /auth/login and /admin/login (in-memory, per process).
AUTH_LOGIN_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC=300
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS=10

# Configure this var in order to return the values of the free text in ENG or DEU, 
# make sure you have configured in OnOffice multilingual, otherwise default DEU
ONOFFICE_ESTATE_LANGUAGE=ENG

# ============================================================
# Bulk geocoding script (optional)
# ============================================================
# Required by scripts/geocode-apartments.js. Use a descriptive identifier
# with app name + contact, per provider requirements.
GEOCODER_USER_AGENT=hope-apartments-geocoder/1.0 (ops@example.com)
# Optional contact email added to the geocoding query.
GEOCODER_EMAIL=ops@example.com
# Optional geocoding country filter. Default "de".
GEOCODER_COUNTRY_CODE=de
# Optional delay between requests in ms. Default 1100 for Nominatim compliance.
GEOCODER_DELAY_MS=1100
# Optional timeout for inline geocoding fallback used by GET /apartments.
GEOCODER_TIMEOUT_MS=4000
