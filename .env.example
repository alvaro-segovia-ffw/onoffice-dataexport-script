# ============================================================
# onOffice upstream credentials (required)
# ============================================================
# Base API URL. Keep the default unless onOffice gives you another endpoint.
ONOFFICE_URL=https://api.onoffice.de/api/stable/api.php
# Your onOffice API token.
ONOFFICE_TOKEN=your_onoffice_token_here
# Your onOffice API secret.
ONOFFICE_SECRET=your_onoffice_secret_here

# ============================================================
# Runtime environment
# ============================================================
# Use "development" for local work, "production" on server.
NODE_ENV=development

# ============================================================
# Database and JWT auth (optional, Phase 2)
# ============================================================
# PostgreSQL connection string for real users in database.
DATABASE_URL=
# Enable SSL for PostgreSQL connections. Recommended in production.
DATABASE_SSL=true
# JWT settings for /auth/login and /auth/me.
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_TTL=15m
JWT_ISSUER=hope-apartments-api
JWT_AUDIENCE=hope-apartments-clients
# Password hashing cost factor.
BCRYPT_ROUNDS=12

# ============================================================
# API server settings
# ============================================================
# HTTP port where this service listens.
EXPORT_API_PORT=3000

# Playground UI (/playground)
# - development: usually true
# - production: recommended false
# If omitted, app defaults to:
# - true when NODE_ENV != production
# - false when NODE_ENV == production
EXPORT_API_ENABLE_PLAYGROUND=true

# Swagger / OpenAPI docs
# If omitted, docs default to:
# - true when NODE_ENV != production
# - false when NODE_ENV == production
DOCS_ENABLED=true

# Rate limiting for GET /apartments (in-memory, per process)
# Example: 60 requests per 60 seconds per token (or IP if token missing).
EXPORT_API_RATE_LIMIT_ENABLED=true
EXPORT_API_RATE_LIMIT_WINDOW_SEC=60
EXPORT_API_RATE_LIMIT_MAX_REQUESTS=60

# ============================================================
# Partner allow-list (required)
# ============================================================
# JSON array of users allowed to call GET /apartments.
# Required keys per item: id, token, secret
# Notes:
# - token must be unique
# - use long random secrets
# - rotate secrets if exposed
# - can be [] after all partners are migrated to X-API-Key
EXPORT_API_USERS=[{"id":"partner-a","token":"partner_a_token","secret":"partner_a_secret_change_me"}]

# Configure this var in order to return the values of the free text in ENG or DEU, 
# make sure you have configured in OnOffice multilingual, otherwise default DEU
ONOFFICE_ESTATE_LANGUAGE=ENG
