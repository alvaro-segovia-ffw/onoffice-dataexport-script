{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/apartments", "destination": "/api/index" },
    { "source": "/playground", "destination": "/api/index" },
    { "source": "/playground/:path*", "destination": "/api/index" },
    { "source": "/", "destination": "/api/index" }
  ]
}
